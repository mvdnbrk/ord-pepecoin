#!/usr/bin/env bash

set -euxo pipefail

version=1.1.0

wget \
  -O pepecoin.tar.gz \
  https://github.com/pepecoinppc/pepecoin/releases/download/v$version/pepecoin-$version-x86_64-linux-gnu.tar.gz

tar \
  -xzvf pepecoin.tar.gz \
  -C /usr/local/bin \
  --strip-components 1 \
  pepecoin-$version/bin/{pepecoin-cli,pepecoind}
